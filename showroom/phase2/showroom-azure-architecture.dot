digraph showroom_phase2 {
  graph [
    rankdir=TB
    fontname="Helvetica"
    fontsize=11
    pad=0.6
    splines=polyline
    bgcolor="white"
    label="PwC Showroom Phase 2 — Azure Architecture\n(QR dropped · Google + Microsoft OAuth · APIM deferred to Phase 3)"
    labelloc=b
    labeljust=c
    nodesep=0.6
    ranksep=0.9
  ]
  node [fontname="Helvetica" fontsize=9 style=filled shape=box]
  edge [fontname="Helvetica" fontsize=8]

  // ─── USERS ───────────────────────────────────────────────────────
  subgraph cluster_users {
    label="Users"
    style=filled fillcolor="#FAFAFA" color="#AAAAAA"
    fontsize=10 fontname="Helvetica-Bold"

    presenter [
      label="Presenter\n(PwC salesperson\nEntra ID login)"
      fillcolor="#FFD8A0" color="#C86400" shape=ellipse
    ]
    prospect [
      label="Prospect\n(external guest\nGoogle or Microsoft login)"
      fillcolor="#BBDEFB" color="#1B4F8A" shape=ellipse
    ]
  }

  // ─── EDGE & DNS ───────────────────────────────────────────────────
  subgraph cluster_edge {
    label="Edge & DNS"
    style=filled fillcolor="#EEEEEE" color="#444444"
    fontsize=10 fontname="Helvetica-Bold"

    dns [
      label="Azure DNS\nshowroom.pwc.example\nadmin.showroom.pwc.example"
      fillcolor="#E0E0E0" color="#444444"
    ]
    afd [
      label="Azure Front Door\nStandard\nGlobal CDN · TLS · multi-origin"
      fillcolor="#D0D0D0" color="#444444"
    ]
    waf [
      label="Front Door WAF Policy\nOWASP CRS 3.2\nBot manager · Rate limit"
      fillcolor="#D0D0D0" color="#444444" shape=diamond
    ]

    dns -> afd [label="CNAME" color="#444444"]
    afd -> waf [label="inspect every\ninbound request" color="#444444"]
  }

  // ─── IDENTITY PROVIDERS ───────────────────────────────────────────
  subgraph cluster_identity {
    label="Identity Providers"
    style=filled fillcolor="#EEEEEE" color="#444444"
    fontsize=10 fontname="Helvetica-Bold"

    entraid [
      label="PwC Entra ID\n(corporate tenant)\nPresenter Admin auth\nPKCE · groups claim"
      fillcolor="#D0D0D0" color="#444444"
    ]
    google_oauth [
      label="Google OAuth 2.0\n(consumer accounts)\nProspect auth"
      fillcolor="#D8F0D8" color="#2E7D32"
    ]
    ms_consumer [
      label="Microsoft OAuth\n(consumer accounts)\nProspect auth"
      fillcolor="#D0E8FF" color="#1B4F8A"
    ]
  }

  // ─── SHOWROOM APPLICATION ─────────────────────────────────────────
  subgraph cluster_showroom_app {
    label="L1 — SHOWROOM  (rg-pwc-showroom-westeurope)"
    style=filled fillcolor="#FFF0E0" color="#C86400"
    fontsize=11 fontname="Helvetica-Bold"

    subgraph cluster_aca {
      label="Azure Container Apps Environment\nshowroom-aca-env  (West Europe · scale 0-10)"
      style=filled fillcolor="#FFE8CC" color="#C86400"
      fontsize=10

      showroom_app [
        label="Container App: showroom-app\n(Next.js — single codebase, two audiences)\n---\n/admin/*  Presenter Admin  (Entra ID session)\n/demo/[id]  Prospect UI  (OAuth session)\n/api/auth/[...nextauth]  All providers\n/api/demos  Authorized demo list\n/api/internal/demo-usage  Callback\n---\nSystem Managed Identity\nScale-to-zero when idle"
        fillcolor="#FFD8A0" color="#C86400"
        width=4.2
      ]
    }

    func_warm [
      label="Azure Function\n(keep-warm)\nTimer: every 5 min\noffice hours only\n~2 EUR/month"
      fillcolor="#FFD8A0" color="#C86400"
      style="filled,dashed"
    ]

    acr [
      label="Azure Container Registry\n(shared)\nshowroom-app:<version>\nSigned images (Notation)\nManaged Identity pull"
      fillcolor="#FFD8A0" color="#C86400" shape=cylinder
    ]

    keyvault [
      label="Azure Key Vault\nAUTH_SECRET\nGoogle client secret\nMicrosoft client secret\ndemo-handoff private key (RSA-256)\nManaged Identity access only"
      fillcolor="#FFF3E0" color="#E65100" shape=cylinder
    ]

    func_warm -> showroom_app [
      label="GET / (keep-warm ping)"
      color="#C86400" fontcolor="#C86400"
      style=dashed
    ]
    acr -> showroom_app [
      label="pull image\n(Managed Identity)"
      color="#C86400" fontcolor="#C86400"
      style=dashed
    ]
    showroom_app -> keyvault [
      label="read secrets\n(Managed Identity)"
      color="#E65100" fontcolor="#E65100"
      style=dashed
    ]
  }

  // ─── TRACKING LAYER (COSMOS DB) ───────────────────────────────────
  subgraph cluster_cosmos {
    label="Tracking Layer — Cosmos DB Serverless\nDatabase: showroom"
    style=filled fillcolor="#FFF8E1" color="#F57F17"
    fontsize=10 fontname="Helvetica-Bold"

    cosmos_users [
      label="Container: users\nPartition: /email\n{ email, provider, allowedDemoIds[]\n  messageQuotaRemaining\n  firstSeenAt, lastSeenAt\n  totalConnections, status }"
      fillcolor="#FFECB3" color="#F57F17" shape=cylinder
    ]
    cosmos_conn [
      label="Container: connection_events\nPartition: /email\n{ email, connectionAt, ip }"
      fillcolor="#FFECB3" color="#F57F17" shape=cylinder
    ]
    cosmos_visits [
      label="Container: demo_visits\nPartition: /email\n{ email, demoId, openedAt\n  closedAt, messageCount }"
      fillcolor="#FFECB3" color="#F57F17" shape=cylinder
    ]
  }

  // ─── OBSERVABILITY ────────────────────────────────────────────────
  subgraph cluster_obs {
    label="Observability"
    style=filled fillcolor="#F5F5F5" color="#888888"
    fontsize=10 fontname="Helvetica-Bold"

    appins [
      label="Application Insights\ncustom events only\nProspectLoggedIn · DemoOpened\nUsageReported\nemail_hashed custom dimension"
      fillcolor="#E8E8E8" color="#888888"
    ]
    loganalytics [
      label="Log Analytics Workspace\nApp Insights telemetry sink\nACA container logs"
      fillcolor="#E8E8E8" color="#888888"
    ]

    appins -> loganalytics [color="#888888"]
  }

  // ─── DEMO APPS ────────────────────────────────────────────────────
  demo_apps [
    label="Demo Apps\n(Overwatch · UBO · ...)\nEach: independent ACA app\nown URL (launchUrl)\nreports messageCount\nvia callback POST"
    fillcolor="#E8F5E9" color="#2E7D32"
    width=3.4
  ]

  // ─── FLOWS ────────────────────────────────────────────────────────

  // Inbound traffic
  presenter -> dns [label="admin.showroom.pwc.example" color="#C86400" fontcolor="#C86400"]
  prospect  -> dns [label="showroom.pwc.example" color="#1B4F8A" fontcolor="#1B4F8A"]
  waf -> showroom_app [label="clean traffic\n(Front Door private link)" color="#444444"]

  // Auth providers -> app
  entraid   -> showroom_app [label="ID token\n(groups claim)" color="#444444" fontcolor="#444444" style=dashed]
  google_oauth  -> showroom_app [label="OAuth callback\n(email, sub)" color="#2E7D32" fontcolor="#2E7D32" style=dashed]
  ms_consumer   -> showroom_app [label="OAuth callback\n(email, sub)" color="#1B4F8A" fontcolor="#1B4F8A" style=dashed]

  // App -> tracking layer
  showroom_app -> cosmos_users  [label="read/write\nallow-list + quota" color="#F57F17" fontcolor="#F57F17"]
  showroom_app -> cosmos_conn   [label="write on every login" color="#F57F17" fontcolor="#F57F17"]
  showroom_app -> cosmos_visits [label="write on demo open\nupdate on callback" color="#F57F17" fontcolor="#F57F17"]

  // App -> observability
  showroom_app -> appins [label="custom events" color="#888888" fontcolor="#888888" style=dashed]

  // JWKS source: Key Vault public key projected into RAM cache
  keyvault -> showroom_app [
    label="public JWK\n(for JWKS endpoint\n15 min RAM cache)"
    color="#E65100" fontcolor="#E65100"
    style=dashed
  ]

  // Demo app launch + callback
  showroom_app -> demo_apps [label="auto-POST form\nJWT handoff (60 s TTL)" color="#2E7D32" fontcolor="#2E7D32"]
  demo_apps -> showroom_app [label="GET /.well-known/jwks.json\n(KV-backed · 24 h client cache)" color="#2E7D32" fontcolor="#2E7D32" style=dashed]
  demo_apps -> showroom_app [label="POST /api/internal/demo-usage\n(messageCount callback)" color="#2E7D32" fontcolor="#2E7D32" style=dashed]

  // ─── LEGEND ───────────────────────────────────────────────────────
  legend [
    shape=none margin=0
    label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="5"
             bgcolor="#F8F8F8" color="#AAAAAA">
        <tr><td colspan="2" align="center"><b>Legend</b></td></tr>
        <tr>
          <td align="right"><b>&#8212;&#8212;</b></td>
          <td align="left">solid = user request path</td>
        </tr>
        <tr>
          <td align="right"><b>- - -</b></td>
          <td align="left">dashed = background / server-to-server / startup</td>
        </tr>
        <tr>
          <td align="right">dashed box</td>
          <td align="left">component not on the per-request critical path</td>
        </tr>
        <tr>
          <td colspan="2">
            <font point-size="9">
              orange = showroom app &#160;&#183;&#160; blue = prospect auth &#160;&#183;&#160;
              green = demo apps &#160;&#183;&#160; amber = tracking layer &#160;&#183;&#160;
              dark = PwC internal
            </font>
          </td>
        </tr>
      </table>
    >
  ]
  { rank=sink; legend }
}

digraph qr_flow {
  graph [
    rankdir=LR
    fontname="Helvetica"
    fontsize=11
    pad=0.5
    splines=true
    bgcolor="white"
    label="PwC Showroom — 1-hour QR-code demo access flow\nDesign decisions: D3 self-signed JWT (RS256) · D8 no Redis (short TTL + Cosmos status check)"
    labelloc=b labeljust=c
    nodesep=0.4
    ranksep=0.7
  ]
  node [fontname="Helvetica" fontsize=10 style=filled shape=box]
  edge [fontname="Helvetica" fontsize=9]

  // ───────────────────────────────────────────────────────────────
  // SWIMLANE A — Presenter (PwC salesperson, internal, Entra ID)
  // ───────────────────────────────────────────────────────────────
  subgraph cluster_presenter {
    label="Presenter (PwC salesperson — Entra ID SSO)"
    style=filled fillcolor="#FFF0E0" color="#C86400"
    fontcolor="#C86400" fontsize=11 fontname="Helvetica-Bold"

    p_laptop [label="Presenter's laptop\n(Showroom Admin UI\nNext.js / MSAL React)" fillcolor="#FFD8A0" color="#C86400"]
    p_bff [label="Showroom BFF\n(POST /sessions)\n1. Mint JWT (5-min TTL)\n2. Write Cosmos record\n3. Emit App Insights event\n4. Return QR image" fillcolor="#FFD8A0" color="#C86400"]
    p_keyvault [label="Key Vault\nRS256 private key\n(Managed Identity access)" fillcolor="#FFD8A0" color="#C86400" shape=cylinder]
    p_cosmos [label="Cosmos DB\nSession record:\n{ sessionId, demoIds[]\n  expiresAt (1h), status }" fillcolor="#FFD8A0" color="#C86400" shape=cylinder]
    p_appins [label="App Insights\nShowroomSessionCreated\n{ sessionId, presenterId\n  demoIds, expiresAt }" fillcolor="#FFD8A0" color="#C86400" shape=ellipse]
    p_qr [label="QR code displayed\nhttps://showroom.pwc.example\n/enter?token=<5-min-JWT>" fillcolor="#FFA040" color="#C86400" fontcolor="white"]

    p_laptop -> p_bff [label="POST /sessions\n{ demoIds[], duration=60m }" color="#C86400" fontcolor="#C86400"]
    p_bff -> p_keyvault [label="sign JWT\n(RS256)" color="#C86400" fontcolor="#C86400"]
    p_bff -> p_cosmos [label="write session record" color="#C86400" fontcolor="#C86400"]
    p_bff -> p_appins [label="audit event" color="#C86400" fontcolor="#C86400" style=dashed]
    p_bff -> p_qr [label="return QR image" color="#C86400" fontcolor="#C86400"]

    p_revoke [label="Presenter clicks\n\"Invalidate\"\nin Admin panel" fillcolor="#FFD8A0" color="#C86400"]
    p_revoke_bff [label="BFF\nPOST /sessions/{id}/revoke\n→ Cosmos status=revoked" fillcolor="#FFD8A0" color="#C86400"]
    p_revoke -> p_revoke_bff [color="#C86400"]
    p_revoke_bff -> p_cosmos [label="status=revoked" color="#C86400" fontcolor="#C86400"]
  }

  // ───────────────────────────────────────────────────────────────
  // SWIMLANE B — Edge & Gateway (Shared Substrate)
  // ───────────────────────────────────────────────────────────────
  subgraph cluster_edge {
    label="L4 Shared Substrate — Identity & Edge + AI Gateway"
    style=filled fillcolor="#F5F5F5" color="#444444"
    fontcolor="#444444" fontsize=11 fontname="Helvetica-Bold"

    fd [label="Azure Front Door\n+ WAF\n(TLS · DDoS · routing)" fillcolor="#E0E0E0" color="#444444"]
    apim [
      label="Azure APIM\nvalidate-jwt (inline RS256)\n• sig + exp + aud checks\nrate-limit-by-key(sub)\ncontent-safety\ncost tagging\naudit → Event Hub"
      fillcolor="#D0D0D0" color="#444444"
    ]
    apim_refresh [
      label="APIM\n/session/refresh route\nvalidates 5-min JWT\nforwards to BFF refresh\nendpoint"
      fillcolor="#D0D0D0" color="#444444"
    ]
    runtime [label="LangGraph Runtime\n(ACA)\n+ MCP tools\n+ LLM" fillcolor="#D0D0D0" color="#444444"]
    auditlog [label="Event Hub\n→ ADLS Gen2\n(immutable audit)" fillcolor="#E8E8E8" color="#888888" shape=ellipse]

    fd -> apim [label="all HTTPS traffic" color="#444444" fontcolor="#444444"]
    apim -> runtime [label="authenticated\nrequests" color="#444444" fontcolor="#444444"]
    apim -> auditlog [label="every request\n(session ID tagged)" style=dashed color="#888888" fontcolor="#888888"]
    apim -> apim_refresh [label="route /session/refresh" color="#444444" fontcolor="#444444" style=dashed]
  }

  // ───────────────────────────────────────────────────────────────
  // SWIMLANE C — Prospect (external guest, phone browser)
  // ───────────────────────────────────────────────────────────────
  subgraph cluster_prospect {
    label="Prospect (external guest — phone browser, no account creation)"
    style=filled fillcolor="#EEF4FF" color="#1B4F8A"
    fontcolor="#1B4F8A" fontsize=11 fontname="Helvetica-Bold"

    phone_scan [label="Phone camera\nscans QR code\nBrowser opens /enter?token=…" fillcolor="#BBDEFB" color="#1B4F8A"]
    phone_enter [label="BFF /enter handler\nvalidates token\n→ sets httpOnly session cookie\n→ redirect /demo/{firstDemoId}" fillcolor="#BBDEFB" color="#1B4F8A"]
    phone_demo [label="Prospect UI\n(Next.js · mobile-first)\n• countdown timer\n• scope-filtered nav menu\n• App Insights RUM" fillcolor="#BBDEFB" color="#1B4F8A"]
    phone_refresh [label="TanStack Query\nsilent refresh hook\nfires every ~4 min\nGET /api/session/refresh" fillcolor="#BBDEFB" color="#1B4F8A"]
    refresh_check [label="BFF /session/refresh\n1. Validate incoming 5-min JWT\n2. Check Cosmos:\n   status == active?\n   now < expiresAt (1h)?\n3. YES → mint new 5-min JWT\n4. NO  → 401 (session ended)" fillcolor="#BBDEFB" color="#1B4F8A"]
    phone_expired [label="\"Session ended\" screen\n(graceful fallback)\n\"Scan a new QR code\nto continue\"" fillcolor="#BBDEFB" color="#1B4F8A" shape=ellipse]

    phone_scan -> phone_enter [color="#1B4F8A"]
    phone_enter -> phone_demo [label="cookie + redirect" color="#1B4F8A" fontcolor="#1B4F8A"]
    phone_demo -> phone_refresh [label="every ~4 min" style=dashed color="#1B4F8A" fontcolor="#1B4F8A"]
    phone_refresh -> refresh_check [color="#1B4F8A"]
    refresh_check -> phone_demo [label="new 5-min JWT\n(transparent to user)" color="#1B4F8A" fontcolor="#1B4F8A" style=dashed]
    refresh_check -> phone_expired [label="401 (expired or revoked)" color="#1B4F8A" fontcolor="#1B4F8A"]
  }

  // ───────────────────────────────────────────────────────────────
  // Cross-swimlane connections
  // ───────────────────────────────────────────────────────────────
  p_qr -> phone_scan [label="salesperson shows QR\nprospect scans" color="#888888" fontcolor="#888888" style=dashed]
  phone_scan -> fd [label="HTTPS / /enter" color="#1B4F8A" fontcolor="#1B4F8A"]
  phone_demo -> fd [label="API calls\n(session cookie → JWT\nin Authorization header)" color="#1B4F8A" fontcolor="#1B4F8A"]
  phone_refresh -> apim_refresh [color="#1B4F8A" fontcolor="#1B4F8A"]
  apim_refresh -> refresh_check [color="#444444" fontcolor="#444444"]
  refresh_check -> p_cosmos [label="read status\n+ expiresAt" color="#888888" fontcolor="#888888" style=dashed]

  // ───────────────────────────────────────────────────────────────
  // Token lifecycle note
  // ───────────────────────────────────────────────────────────────
  token_note [
    label="Token model (no Redis):\n• Access JWT TTL = 5 min (RS256, Key Vault signed)\n• Session horizon = 1 hour (Cosmos record expiresAt)\n• Silent refresh every ~4 min keeps prospect seamlessly in\n• Revocation: set status=revoked in Cosmos →\n  next refresh fails → current 5-min JWT dies ≤ 5 min\n• Natural expiry: 1-hour Cosmos horizon exceeded → 401"
    shape=note style=filled fillcolor="#FFFBE6" color="#B8860B"
    fontcolor="#B8860B" fontsize=9
  ]
}

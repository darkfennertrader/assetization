digraph phase3 {
  graph [
    rankdir=TB
    fontname="Helvetica"
    fontsize=11
    pad=0.7
    splines=polyline
    bgcolor="white"
    label="PwC AI Platform — Phase 3 Target Architecture\nAPIM as single enforcement point · Entra ID + Google + MS consumer as identity providers · OpenFGA for fine-grained authZ"
    labelloc=b labeljust=c
    nodesep=0.6
    ranksep=0.9
  ]
  node [fontname="Helvetica" fontsize=9 style=filled shape=box]
  edge [fontname="Helvetica" fontsize=8]

  // ──────────────────────────────────────────────────────────────────────────
  // BAND 1 — Users
  // ──────────────────────────────────────────────────────────────────────────
  subgraph cluster_users {
    label="Users"
    style=filled fillcolor="#FAFAFA" color="#AAAAAA"
    fontsize=10 fontname="Helvetica-Bold"

    presenter [
      label="Presenter / PwC employee\n(salesperson, consultant, internal)\nEntra ID workforce credentials"
      fillcolor="#FFD8A0" color="#C86400" shape=ellipse
    ]
    prospect [
      label="Prospect / external customer\n(Google or Microsoft\nconsumer account)"
      fillcolor="#BBDEFB" color="#1B4F8A" shape=ellipse
    ]
  }

  // ──────────────────────────────────────────────────────────────────────────
  // BAND 2 — Edge
  // ──────────────────────────────────────────────────────────────────────────
  subgraph cluster_edge {
    label="Edge (public HTTPS)"
    style=filled fillcolor="#EEEEEE" color="#444444"
    fontsize=10 fontname="Helvetica-Bold"

    dns [
      label="Azure DNS\n*.pwc.example"
      fillcolor="#E0E0E0" color="#444444"
    ]
    afd [
      label="Azure Front Door Standard\nGlobal anycast · TLS termination\nCustom domains · Multi-origin failover"
      fillcolor="#D0D0D0" color="#444444"
    ]
    waf [
      label="WAF Policy\nOWASP CRS 3.2\nBot manager · Edge rate limit"
      fillcolor="#D0D0D0" color="#444444" shape=diamond
    ]

    dns -> afd [label="CNAME" color="#444444"]
    afd -> waf  [label="inspect every request" color="#444444"]
  }

  // ──────────────────────────────────────────────────────────────────────────
  // BAND 3 — APIM (THE single enforcement point)
  // ──────────────────────────────────────────────────────────────────────────
  subgraph cluster_apim {
    label="L2 — APIM  (single enforcement point for AuthN · AuthZ · Safety · Audit)"
    style=filled fillcolor="#E3F2FD" color="#1B4F8A"
    fontsize=11 fontname="Helvetica-Bold"

    apim_core [
      label="Azure API Management\n(Standard v2 — shared across all products)\n─────────────────────────────────────────────\nPolicy pipeline (executed per request):\n 1.  validate-jwt  →  accept tokens from PwC Entra ID\n                       OR Google OAuth\n                       OR Microsoft consumer OAuth\n 2.  call OpenFGA  →  check (user, demo/feature, read)\n 3.  rate-limit-by-key  →  per email per product\n 4.  Azure AI Content Safety  →  input/output scan\n 5.  route to backend by product prefix\n 6.  emit to Event Hub  →  ADLS Gen2 WORM audit log\n─────────────────────────────────────────────\nAPIM is the ONLY component that backends trust.\nAll JWTs must pass validate-jwt before any\nrequest reaches ACA / AKS / Databricks."
      fillcolor="#BBDEFB" color="#1B4F8A"
      width=5.5
    ]

    content_safety [
      label="Azure AI Content Safety\n(called by APIM policy)\nInput screen: prompt injection\nOutput screen: harmful content\nConfigurable per product"
      fillcolor="#C8E6FF" color="#1B4F8A"
      style="filled,dashed"
    ]

    eventhub [
      label="Azure Event Hub\nAudit stream\nAll API calls tagged with\nemail · product · demoId\ntimestamp · statusCode"
      fillcolor="#C8E6FF" color="#1B4F8A"
      style="filled,dashed"
    ]

    adls [
      label="ADLS Gen2\n(WORM immutable audit log)\nRetention: 7 years\nLegal / compliance requirement"
      fillcolor="#C8E6FF" color="#1B4F8A"
      style="filled,dashed" shape=cylinder
    ]

    apim_core -> content_safety [label="inline policy call" color="#1B4F8A" style=dashed]
    apim_core -> eventhub      [label="emit per request"  color="#1B4F8A" style=dashed]
    eventhub   -> adls         [label="stream to WORM"    color="#1B4F8A" style=dashed]
  }

  // ──────────────────────────────────────────────────────────────────────────
  // BAND 4 — Identity Providers (issuers only — APIM validates their tokens)
  // ──────────────────────────────────────────────────────────────────────────
  subgraph cluster_idp {
    label="Identity Providers  (issue tokens · APIM validates them)"
    style=filled fillcolor="#F3F3F3" color="#777777"
    fontsize=10 fontname="Helvetica-Bold"

    entraid [
      label="PwC Entra ID\n(workforce tenant)\nFor: PwC employees\nIssues: access + ID tokens\nMFA enforced"
      fillcolor="#D0D0D0" color="#444444"
    ]
    google_idp [
      label="Google OAuth 2.0\n(consumer accounts)\nFor: external prospects\nIssues: ID token (email, sub)\nNo PwC account needed"
      fillcolor="#D8F0D8" color="#2E7D32"
    ]
    ms_consumer_idp [
      label="Microsoft OAuth\n(consumer accounts)\nFor: external prospects\nIssues: ID token (email, sub)\nNo PwC account needed"
      fillcolor="#D0E8FF" color="#1B4F8A"
    ]
  }

  // ──────────────────────────────────────────────────────────────────────────
  // BAND 5 — Fine-grained AuthZ
  // ──────────────────────────────────────────────────────────────────────────
  subgraph cluster_authz {
    label="Fine-grained AuthZ"
    style=filled fillcolor="#FFF8E1" color="#F57F17"
    fontsize=10 fontname="Helvetica-Bold"

    openfga [
      label="OpenFGA\n(relation-based authorization)\nTuples: (user, relation, object)\nExample:\n  prospect:jane@ex.com\n  can:open\n  demo:overwatch\nAPIM policy calls /check before routing"
      fillcolor="#FFECB3" color="#F57F17"
    ]

    cosmos_authz [
      label="Cosmos DB\nusers container\nallow-list · quota\nallowedDemoIds[]\nRead by OpenFGA adapter"
      fillcolor="#FFECB3" color="#F57F17" shape=cylinder
    ]

    openfga -> cosmos_authz [label="reads tuples" color="#F57F17" style=dashed]
  }

  // ──────────────────────────────────────────────────────────────────────────
  // BAND 6 — Tier 1 front-ends (Showroom + Marketplace)
  // ──────────────────────────────────────────────────────────────────────────
  subgraph cluster_tier1 {
    label="L1 — Tier 1 Products  (consumer-facing surfaces)"
    style=filled fillcolor="#FFF0E0" color="#C86400"
    fontsize=11 fontname="Helvetica-Bold"

    showroom [
      label="Showroom\n(ACA — Next.js)\nExternal prospects\nPersonalised demo catalog\nUsage tracking + quota"
      fillcolor="#FFD8A0" color="#C86400"
    ]

    marketplace [
      label="Marketplace\n(ACA — Next.js)\nInternal PwC employees\nBrowse + launch assetized tools\nCost tagging per team"
      fillcolor="#FFD8A0" color="#C86400"
    ]
  }

  // ──────────────────────────────────────────────────────────────────────────
  // BAND 7 — Tier 2 — Assetized applications (AKS + Databricks)
  // ──────────────────────────────────────────────────────────────────────────
  subgraph cluster_tier2 {
    label="L3 — Assetized Applications  (exposed as MCP tools or A2A agents)"
    style=filled fillcolor="#E8F5E9" color="#2E7D32"
    fontsize=11 fontname="Helvetica-Bold"

    aks_apps [
      label="AKS cluster\nOverwatch (supply-chain AI)\nUBO (KYC screening)\nOther assetized demos\n─────────────────\nExposed as MCP tool endpoints\nor A2A agent APIs\nJWT required (issued by IdPs)\nvalidated by APIM before routing"
      fillcolor="#C8E6C9" color="#2E7D32"
    ]

    databricks_apps [
      label="Databricks (optional)\nData-intensive assets:\nforecasting, analytics, ML\nExposed as REST APIs\nbehind APIM routing rules\nSame JWT validation"
      fillcolor="#C8E6C9" color="#2E7D32"
      style="filled,dashed"
    ]
  }

  // ──────────────────────────────────────────────────────────────────────────
  // FLOW EDGES — cross-band
  // ──────────────────────────────────────────────────────────────────────────

  // Users -> Edge
  presenter -> dns [label="showroom.pwc.example\nadmin.showroom.pwc.example\nmarketplace.pwc.example" color="#C86400" fontcolor="#C86400"]
  prospect  -> dns [label="showroom.pwc.example" color="#1B4F8A" fontcolor="#1B4F8A"]

  // Edge -> APIM
  waf -> apim_core [label="clean traffic\n(Front Door private link)" color="#444444"]

  // IdPs issue tokens; APIM validates
  entraid        -> apim_core [label="issues JWT\n(validate-jwt in APIM)" color="#444444" fontcolor="#444444" style=dashed]
  google_idp     -> apim_core [label="issues JWT\n(validate-jwt in APIM)" color="#2E7D32" fontcolor="#2E7D32" style=dashed]
  ms_consumer_idp -> apim_core [label="issues JWT\n(validate-jwt in APIM)" color="#1B4F8A" fontcolor="#1B4F8A" style=dashed]

  // APIM -> OpenFGA (authZ check)
  apim_core -> openfga [label="check(user, relation, object)\nbefore routing" color="#F57F17" fontcolor="#F57F17"]

  // APIM -> Tier 1
  apim_core -> showroom    [label="route: /showroom/*\n(JWT validated, authZ passed)" color="#C86400" fontcolor="#C86400"]
  apim_core -> marketplace [label="route: /marketplace/*\n(PwC employee only)" color="#C86400" fontcolor="#C86400"]

  // APIM -> Tier 2 (direct or via Tier 1 back-channel)
  apim_core -> aks_apps       [label="route: /api/v1/*\nMCP / A2A endpoints" color="#2E7D32" fontcolor="#2E7D32"]
  apim_core -> databricks_apps [label="route: /api/data/*\nanalytics / ML" color="#2E7D32" fontcolor="#2E7D32" style=dashed]

  // Tier 1 -> Tier 2 (internal back-channel, still through APIM)
  showroom    -> apim_core [label="internal back-channel\n(also through APIM)" color="#C86400" fontcolor="#C86400" style=dashed]
  marketplace -> apim_core [label="internal back-channel\n(also through APIM)" color="#C86400" fontcolor="#C86400" style=dashed]

  // ──────────────────────────────────────────────────────────────────────────
  // LEGEND + KEY PRINCIPLE NOTE
  // ──────────────────────────────────────────────────────────────────────────
  legend [
    shape=none margin=0
    label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="5"
             bgcolor="#F8F8F8" color="#AAAAAA">
        <tr><td colspan="2" align="center"><b>Phase 3 — Key Principles</b></td></tr>
        <tr>
          <td align="right"><b>APIM</b></td>
          <td align="left">single enforcement point — AuthN + AuthZ + Safety + Audit. Backends trust ONLY APIM.</td>
        </tr>
        <tr>
          <td align="right"><b>Entra ID / Google / MS consumer</b></td>
          <td align="left">identity providers only — issue JWTs. APIM validate-jwt accepts all three issuers.</td>
        </tr>
        <tr>
          <td align="right"><b>OpenFGA</b></td>
          <td align="left">fine-grained authZ engine — called by APIM policy (not by apps). Replaces Cosmos allow-list array.</td>
        </tr>
        <tr>
          <td align="right"><b>Phase 2 compat</b></td>
          <td align="left">Showroom + Marketplace app code unchanged. APIM inserted as new L2 tier. No app rewrites.</td>
        </tr>
        <tr>
          <td align="right"><b>Cost sharing</b></td>
          <td align="left">APIM Standard v2 (~220 EUR/month) shared across ALL products. Per-product marginal cost near zero.</td>
        </tr>
        <tr>
          <td colspan="2">
            <font point-size="8">
              orange = Tier 1 products &#160;&#183;&#160; blue = APIM enforcement &#160;&#183;&#160;
              green = assetized apps &#160;&#183;&#160; amber = authZ / data &#160;&#183;&#160;
              dashed = background / audit / optional path
            </font>
          </td>
        </tr>
      </table>
    >
  ]
  { rank=sink; legend }
}

digraph three_tier {
  graph [
    rankdir=TB
    fontname="Helvetica"
    fontsize=11
    pad=0.6
    splines=false
    bgcolor="white"
    label="PwC AI Platform — Three-Tier Architecture"
    labelloc=t
    labeljust=c
    nodesep=0.6
    ranksep=0.7
  ]
  node [fontname="Helvetica" fontsize=10 style=filled shape=box margin="0.35,0.2"]
  edge [fontname="Helvetica" fontsize=9 color="#444444"]

  // ─── Audience nodes (top row) ─────────────────────────────────────────────
  pwc_employees [
    label="PwC EMPLOYEES\nCopilot · Cursor · Claude · LangGraph\n(internal dev tools)\n\nPrivate ingress — Entra ID\nPwC LAN / corporate VPN only"
    fillcolor="#C8E6C9" color="#2E7D32" fontcolor="#2E7D32"
    width=3.8 height=1.1
  ]

  ext_clients [
    label="EXTERNAL CLIENTS\nMCP server deployed into\nclient's own Azure subscription\n(no access to PwC Marketplace)\n\nPublic ingress — Entra External ID\nFront Door + WAF"
    fillcolor="#FFD8A0" color="#C86400" fontcolor="#C86400"
    width=3.8 height=1.1
  ]

  {rank=same pwc_employees ext_clients}

  // ─── Tier 1 ───────────────────────────────────────────────────────────────
  tier1 [
    label="TIER 1 — USER SURFACES\n\nMarketplace (internal PwC staff — asset catalogue, Entra ID SSO)\nShowroom (external prospects — QR code, 1-hour session)\n+ optional app-specific UIs where a chat surface is not enough"
    fillcolor="#FFF0E0" color="#C86400" fontcolor="#333333"
    width=8.0 height=1.2
  ]

  // ─── Tier 2 ───────────────────────────────────────────────────────────────
  tier2 [
    label="TIER 2 — SHARED CONTROL PLANE  (built once — never duplicated)\n\nAzure APIM  ·  Entra ID (staff SSO)  ·  Entra External ID (guests / clients)\nOpenFGA (fine-grained authorisation)  ·  Audit Log  ·  Key Vault"
    fillcolor="#F0F0F0" color="#444444" fontcolor="#333333"
    width=8.0 height=1.1
  ]

  // ─── Tier 3 ───────────────────────────────────────────────────────────────
  tier3 [
    label="TIER 3 — CAPABILITIES  (all exposed via MCP / A2A contract)\n\n[ Azure Container Apps — default · stateless tools · scale-to-zero ]\n[ Databricks — data-heavy · Data Lakehouse · Unity Catalog governance ]\n[ AKS — heavy workloads · GPU inference · complex sidecars ]"
    fillcolor="#EEF4FF" color="#1B4F8A" fontcolor="#1B4F8A"
    width=8.0 height=1.3
  ]

  // ─── Edges — audiences to Tier 1 ─────────────────────────────────────────
  pwc_employees -> tier1 [
    label="private endpoint\n(Marketplace + internal MCP tools)"
    color="#2E7D32" fontcolor="#2E7D32"
  ]
  ext_clients -> tier1 [
    label="Showroom demos\n(public — WAF-fronted)"
    color="#C86400" fontcolor="#C86400"
  ]

  // For clients the MCP server is deployed into their infra — show that bypass
  ext_clients -> tier3 [
    label="engagement provisioning:\nMCP server deployed into\nclient's own subscription\n(signed container from PwC ACR)"
    color="#C86400" fontcolor="#C86400"
    style=dashed
  ]

  // ─── Tier-to-tier flows ───────────────────────────────────────────────────
  tier1 -> tier2 [label="all requests\n(token · rate limit · safety · audit)" color="#444444" fontcolor="#444444"]
  tier2 -> tier3 [label="validated request\nrouted to capability" color="#444444" fontcolor="#444444"]

  // ─── Legend note ─────────────────────────────────────────────────────────
  legend [
    label="Solid arrows: live request path\nDashed arrow: deploy-time provisioning (not a live connection)\nTier 2 is the only entry point to Tier 3 at runtime"
    shape=note style=filled fillcolor="#FFFBE6" color="#B8860B"
    fontcolor="#B8860B" fontsize=9
  ]
}
